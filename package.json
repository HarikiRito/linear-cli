{
  "name": "linear-cli",
  "version": "0.1.0",
  "description": "CLI for Linear — designed for agent/programmatic use",
  "type": "commonjs",
  "bin": {
    "linear": "./dist/index.cjs"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "biome format --write src tests",
    "lint": "biome check src tests && eslint src tests",
    "lint:fix": "biome check --write --unsafe src tests && eslint --fix src tests"
  },
  "dependencies": {
    "@clack/prompts": "^0.9.0",
    "@linear/sdk": "^22.0.0",
    "cli-table3": "^0.6.5",
    "commander": "^12.0.0",
    "neverthrow": "^8.0.0",
    "open": "^9.1.0",
    "ora": "^8.2.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.0.0",
    "eslint": "^10.5.0",
    "tsdown": "^0.22.3",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.62.0",
    "vitest": "^3.0.0"
  }
}
