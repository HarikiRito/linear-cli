{
  "name": "@harikidev/linear-cli",
  "version": "0.2.1",
  "description": "CLI for Linear — designed for agent/programmatic use",
  "type": "commonjs",
  "repository": { "type": "git", "url": "git+https://github.com/HarikiRito/linear-cli.git" },
  "bugs": { "url": "https://github.com/HarikiRito/linear-cli/issues" },
  "homepage": "https://github.com/HarikiRito/linear-cli#readme",
  "bin": {
    "linear": "./dist/index.cjs"
  },
  "license": "Apache-2.0",
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "skill/**"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "build": "tsdown",
    "prepublishOnly": "npm run build && npm run generate:skill",
    "dev": "tsdown --watch",
    "codegen": "graphql-codegen --config codegen.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "pnpm build && RUN_E2E=1 vitest run tests/e2e",
    "generate:skill": "tsx scripts/generate-skill.ts",
    "format": "biome format --write src tests",
    "lint": "biome check src tests && eslint src tests",
    "lint:fix": "biome check --write --unsafe src tests && eslint --fix src tests"
  },
  "dependencies": {
    "@clack/prompts": "^0.9.0",
    "@graphql-typed-document-node/core": "^3.2.0",
    "@linear/sdk": "^22.0.0",
    "cli-table3": "^0.6.5",
    "commander": "^12.0.0",
    "neverthrow": "^8.0.0",
    "open": "^9.1.0",
    "picocolors": "^1.1.1",
    "smol-toml": "^1.7.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@eslint/js": "^10.0.1",
    "@graphql-codegen/cli": "^5.0.0",
    "@graphql-codegen/client-preset": "^4.0.0",
    "@types/node": "^22.0.0",
    "eslint": "^10.5.0",
    "graphql": "^16.0.0",
    "tsdown": "^0.22.3",
    "tsx": "^4.22.4",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.62.0",
    "vitest": "^3.0.0"
  }
}
