{
	"$schema": "https://biomejs.dev/schemas/2.5.1/schema.json",
	"files": {
		"includes": [
			"src/**/*.ts",
			"src/**/*.js",
			"*.json",
			"*.ts",
			"*.js",
			"!**/*.svelte",
			"!**/.svelte-kit",
			"!**/node_modules",
			"!**/build",
			"!**/dist",
			"!**/coverage",
			"!**/.ai",
			"!src/components/ui/**/index.ts"
		]
	},
	"linter": {
		"enabled": true,
		"rules": {
			"preset": "recommended",
			"style": {
				"useConst": "error",
				"noNonNullAssertion": "off",
				"useBlockStatements": "off",
				"noParameterAssign": "warn"
			},
			"suspicious": {
				"noExplicitAny": "error",
				"noVar": "error",
				"noRedeclare": "warn",
				"noShadowRestrictedNames": "warn",
				"noArrayIndexKey": "off"
			},
			"complexity": {
				"noForEach": "off",
				"noBannedTypes": "warn",
				"useArrowFunction": "off",
				"noStaticOnlyClass": "off",
				"noThisInStatic": "off"
			},
			"a11y": {
				"useKeyWithClickEvents": "warn",
				"useFocusableInteractive": "warn",
				"noSvgWithoutTitle": "warn"
			},
			"security": {
				"noDangerouslySetInnerHtml": "warn"
			}
		}
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"indentWidth": 2,
		"lineWidth": 100
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "single",
			"trailingCommas": "none"
		}
	},
	"assist": { "actions": { "source": { "organizeImports": "on" } } }
}
